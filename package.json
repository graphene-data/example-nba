{
  "name": "example-nba",
  "version": "0.0.1",
  "scripts": {
    "graphene": "graphene",
    "serve": "graphene serve",
    "setup": "curl -L 'https://graphene-demos.s3.us-east-1.amazonaws.com/nba.duckdb' -o nba.duckdb",
    "compile": "graphene compile",
    "run": "graphene run"
  },
  "dependencies": {
    "@duckdb/node-api": "1.3.2-alpha.26",
    "@graphenedata/cli": "0.0.19"
  },
  "graphene": {
    "dialect": "duckdb",
    "duckdb": {
      "path": "./nba.duckdb"
    }
  }
}
